# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.installed.cfg
*.egg

# --- Virtual envs ---
.venv/
venv/
env/
.conda/

# --- Env / secrets (NEVER commit — global creds live in ~/.env) ---
.env
.env.*
!.env.example
*.key
*.pem
secrets.yaml

# --- Notebooks ---
.ipynb_checkpoints/

# --- Testing / coverage ---
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# --- ML / model artifacts (large — keep out of git) ---
models/
*.gguf
*.bin
*.safetensors
*.pt
*.pth
*.onnx
*.npz
adapters/
checkpoints/
wandb/
mlruns/
.dvc/cache/

# --- Data (versioned via DVC or downloaded by scripts, not git) ---
# Everything under data/ is fetched, never committed: `make corpus` clones ~370 MB of
# duckdb-web into data/.cache/ and stages the corpus into data/corpus/. Reproducibility
# comes from the pinned commit sha, not from checking the bytes in.
data/
!data/.gitkeep
*.sqlite
*.db
*.duckdb

# --- Vector stores / indexes ---
# NOT a bare `index/`: that pattern matches at any depth and silently swallowed the whole
# `src/index/` source package, which shipped an M0 commit that could not import. Anchor
# built indexes to where they actually live (data/ is already ignored wholesale above).
*.faiss
/backend/data/index/
.chroma/

# --- Logs / traces ---
logs/
*.log
traces/

# --- OS ---
.DS_Store
.AppleDouble
._*
.Spotlight-V100
.Trashes

# --- IDE ---
.vscode/
.idea/
*.swp

# Promoted flywheel artifacts are config, not data — a clone must be able to serve the
# active config, so configs/ is exempted from the *.bin rule above.
!backend/configs/candidates/*.bin
